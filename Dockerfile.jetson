# =============================================================================
# ACE-Step 1.5 — Runpod Serverless / Datacenter GPU Dockerfile
# =============================================================================
# Target: Runpod Serverless (load-balanced/custom API endpoint) or standard Pod
# Platform: linux/amd64 with NVIDIA datacenter GPUs
#
# Build example:
#   docker build --platform linux/amd64 -f Dockerfile.runpod -t youruser/acestep-runpod:latest .
#
# Model options:
#   1) Mount models at runtime under /models (recommended)
#   2) Bake them in from your own URLs at build time by setting MODEL_SOURCE=url
#
# Runtime examples:
#   docker run --gpus all -p 8001:8001 -p 7860:7860 \
#     -v /host/models:/models \
#     youruser/acestep-runpod:latest
#
# Notes:
#   - No Hugging Face token is baked into this image.
#   - This image is intentionally NOT Jetson/L4T based.
# =============================================================================

FROM nvidia/cuda:12.4.1-cudnn-devel-ubuntu22.04

ENV DEBIAN_FRONTEND=noninteractive \
    LANG=C.UTF-8 \
    LC_ALL=C.UTF-8 \
    PYTHONUNBUFFERED=1 \
    PIP_NO_CACHE_DIR=1 \
    TOKENIZERS_PARALLELISM=false

# -------------------- System dependencies --------------------
RUN apt-get update && apt-get install -y --no-install-recommends \
    software-properties-common \
    build-essential \
    cmake \
    git \
    curl \
    wget \
    pkg-config \
    ca-certificates \
    python3 \
    python3-dev \
    python3-pip \
    python3-venv \
    libsndfile1 \
    libsndfile1-dev \
    nasm \
    yasm \
    libx264-dev \
    libx265-dev \
    libmp3lame-dev \
    libopus-dev \
    libvorbis-dev \
    libopenblas-dev \
    liblapack-dev \
    gfortran \
 && rm -rf /var/lib/apt/lists/*

RUN ln -sf /usr/bin/python3 /usr/bin/python \
 && python -m pip install --upgrade pip setuptools wheel

# -------------------- FFmpeg 7 for newer audio stacks --------------------
ARG FFMPEG_VERSION=7.1
RUN cd /tmp \
 && curl -fSL "https://ffmpeg.org/releases/ffmpeg-${FFMPEG_VERSION}.tar.xz" -o ffmpeg.tar.xz \
 && tar xf ffmpeg.tar.xz \
 && cd ffmpeg-${FFMPEG_VERSION} \
 && ./configure \
      --prefix=/usr/local \
      --enable-shared \
      --disable-static \
      --enable-gpl \
      --enable-libx264 \
      --enable-libx265 \
      --enable-libmp3lame \
      --enable-libopus \
      --enable-libvorbis \
      --disable-doc \
      --disable-programs \
 && make -j"$(nproc)" \
 && make install \
 && ldconfig \
 && cd /tmp \
 && rm -rf ffmpeg*

# -------------------- PyTorch CUDA stack --------------------
ARG TORCH_INDEX_URL=https://download.pytorch.org/whl/cu124
ARG TORCH_VERSION=2.5.1
ARG TORCHVISION_VERSION=0.20.1
ARG TORCHAUDIO_VERSION=2.5.1
RUN pip install --no-cache-dir \
    --index-url ${TORCH_INDEX_URL} \
    torch==${TORCH_VERSION} \
    torchvision==${TORCHVISION_VERSION} \
    torchaudio==${TORCHAUDIO_VERSION}

# -------------------- App source --------------------
WORKDIR /app
COPY . /app/

# -------------------- Python dependencies --------------------
RUN pip install --no-cache-dir \
    "numpy>=1.24,<2.0" \
    "transformers>=4.51.0,<4.58.0" \
    diffusers \
    "gradio==6.2.0" \
    "matplotlib>=3.7.5" \
    "scipy>=1.10.1" \
    "soundfile>=0.13.1" \
    "loguru>=0.7.3" \
    "einops>=0.8.1" \
    "accelerate>=1.12.0" \
    "fastapi>=0.110.0" \
    diskcache \
    "uvicorn[standard]>=0.27.0" \
    "numba>=0.60.0" \
    "vector-quantize-pytorch>=1.27.15" \
    toml \
    safetensors \
    modelscope \
    "peft>=0.18.0" \
    lycoris-lora \
    "lightning>=2.0.0" \
    "tensorboard>=2.20.0" \
    "typer-slim>=0.21.1" \
    xxhash \
    pyyaml \
    "bitsandbytes>=0.43.0"



RUN if [ -d /app/acestep/third_parts/nano-vllm ]; then \
      pip install --no-cache-dir --no-deps /app/acestep/third_parts/nano-vllm; \
    fi

# -------------------- Model layout --------------------
ARG MODEL_ROOT=/models
ARG MODEL_SOURCE=none
ARG MAIN_MODEL_URL=none
ARG BASE_MODEL_URL=http://98.82.28.3/tmp/acestep-v15-base.tar.gz
ARG LM_MODEL_URL=http://98.82.28.3/tmp/acestep-5Hz-lm-4B.tar.gz
ARG TURBO_MODEL_URL=http://98.82.28.3/tmp/acestep-v15-turbo.tar.gz

ENV MODEL_ROOT=${MODEL_ROOT} \
    ACESTEP_MODE=api \
    ACESTEP_API_HOST=0.0.0.0 \
    GRADIO_SERVER_NAME=0.0.0.0 \
    ACESTEP_INIT_SERVICE=true \
    ACESTEP_LLM_BACKEND=vllm \
    ACESTEP_CONFIG_PATH=acestep-v15-turbo \
    ACESTEP_LM_MODEL_PATH=${MODEL_ROOT}/acestep-5Hz-lm-4B

RUN mkdir -p ${MODEL_ROOT} /app/gradio_outputs

RUN pip install --no-cache-dir runpod requests
CMD ["python", "-u", "handler.py"]

RUN set -eux; \
    if [ "${MODEL_SOURCE}" = "url" ]; then \
      cd /tmp; \
      for url in "${MAIN_MODEL_URL}" "${BASE_MODEL_URL}" "${LM_MODEL_URL}" "${TURBO_MODEL_URL}"; do \
        if [ -n "$url" ]; then \
          fname=$(basename "$url"); \
          curl -fL "$url" -o "$fname"; \
          case "$fname" in \
            *.tar.gz|*.tgz) tar -xzf "$fname" -C ${MODEL_ROOT} ;; \
            *.tar.xz) tar -xJf "$fname" -C ${MODEL_ROOT} ;; \
            *.zip) apt-get update && apt-get install -y --no-install-recommends unzip && unzip -q "$fname" -d ${MODEL_ROOT} && rm -rf /var/lib/apt/lists/* ;; \
            *) echo "Unsupported archive format: $fname" && exit 1 ;; \
          esac; \
          rm -f "$fname"; \
        fi; \
      done; \
    fi

EXPOSE 7860 8001

HEALTHCHECK --interval=60s --timeout=10s --start-period=120s --retries=3 \
  CMD curl -sf http://localhost:${ACESTEP_API_PORT:-8001}/health > /dev/null 2>&1 \
   || curl -sf http://localhost:${GRADIO_PORT:-7860}/ > /dev/null 2>&1 \
   || exit 1

COPY <<'EOF2' /app/docker-entrypoint.sh
#!/usr/bin/env bash
set -e

echo "==========================================="
echo "  ACE-Step 1.5 — Runpod CUDA Container"
echo "==========================================="
echo "Mode      : ${ACESTEP_MODE}"
echo "Python    : $(python --version 2>&1)"
echo "PyTorch   : $(python -c 'import torch; print(torch.__version__)' 2>/dev/null || echo 'N/A')"

if python -c 'import torch; assert torch.cuda.is_available()' 2>/dev/null; then
    echo "CUDA      : $(python -c 'import torch; print(torch.version.cuda)')"
    echo "GPU       : $(python -c 'import torch; print(torch.cuda.get_device_name(0))')"
    echo "Memory    : $(python -c 'import torch; p=torch.cuda.get_device_properties(0); print(f"{p.total_memory/1024**3:.1f} GB")')"
else
    echo "CUDA      : NOT AVAILABLE"
fi

echo "MODEL_ROOT : ${MODEL_ROOT}"
echo "CONFIG     : ${ACESTEP_CONFIG_PATH}"
echo "LM MODEL   : ${ACESTEP_LM_MODEL_PATH}"
echo "==========================================="

INIT_ARGS=""
if [ "${ACESTEP_INIT_SERVICE:-true}" = "true" ]; then
    INIT_ARGS="--init_service true"
    [ -n "${ACESTEP_CONFIG_PATH:-}" ]   && INIT_ARGS="${INIT_ARGS} --config_path ${ACESTEP_CONFIG_PATH}"
    [ -n "${ACESTEP_LM_MODEL_PATH:-}" ] && INIT_ARGS="${INIT_ARGS} --init_llm true --lm_model_path ${ACESTEP_LM_MODEL_PATH}"
fi

if [ "${ACESTEP_MODE}" = "gradio" ]; then
    exec python -m acestep.acestep_v15_pipeline \
        --server-name "${GRADIO_SERVER_NAME:-0.0.0.0}" \
        --port "${GRADIO_PORT:-7860}" \
        --backend "${ACESTEP_LLM_BACKEND:-pt}" \
        ${INIT_ARGS} \
        ${ACESTEP_EXTRA_ARGS:-}
else
    exec python -m acestep.api_server \
        --host "${ACESTEP_API_HOST:-0.0.0.0}" \
        --port "${ACESTEP_API_PORT:-8001}" \
        ${ACESTEP_EXTRA_ARGS:-}
fi
EOF2

RUN chmod +x /app/docker-entrypoint.sh
ENTRYPOINT ["/app/docker-entrypoint.sh"]
